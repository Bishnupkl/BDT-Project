# Kafka Configuration
KAFKA_TOPIC=crypto-topic
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Spark Configuration
SPARK_MASTER_URL=spark://spark-master:7077
CRYPTO_METADATA_PATH=/opt/spark-app/metadata/crypto_metadata.csv
SPARK_PARQUET_OUTPUT_PATH=/opt/spark-app/storage/crypto_analytics.db
SPARK_CHECKPOINT_PATH=/opt/spark-app/storage/checkpoints
SPARK_WAREHOUSE_DIR=/opt/spark-app/storage

# Producer Configuration
# Interval between generated events in milliseconds
PRODUCER_INTERVAL_MS=1000

# Maximum number of events to produce before shutting down (0 = run forever)
PRODUCER_MAX_EVENTS=0
