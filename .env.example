# Kafka Configuration
KAFKA_TOPIC=crypto-topic
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Producer Configuration
# Interval between generated events in milliseconds
# The producer will wait this amount (minimum 10s) between standard API calls.
# Note: To respect CoinGecko rate limits, the producer will automatically
# enforce a 60-second cooldown after every 15 events.
PRODUCER_INTERVAL_MS=10000

# Maximum number of events to produce before shutting down (0 = run forever)
PRODUCER_MAX_EVENTS=0